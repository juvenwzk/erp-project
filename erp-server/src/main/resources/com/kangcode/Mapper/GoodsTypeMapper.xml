<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kangcode.Mapper.GoodsTypeMapper">

    <insert id="insertById" useGeneratedKeys="true" keyProperty="id">
        insert into goods_type(type_name,remark) values(#{typeName},#{remark})
    </insert>
    <update id="updateById">
        update goods_type set
        type_name=#{typeName},
        remark=#{remark}
        where id=#{id}
    </update>
    <delete id="deleteById">
        delete from goods_type where id=#{id}
    </delete>
    <select id="list" resultType="com.kangcode.pojo.GoodsType">
        select * from goods_type
    </select>
</mapper>