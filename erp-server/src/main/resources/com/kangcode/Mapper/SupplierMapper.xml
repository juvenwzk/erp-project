<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kangcode.Mapper.SupplierMapper">

    <!-- 字段映射：将DB列名映射到实体类字段 -->
    <resultMap id="supplierMap" type="com.kangcode.pojo.Supplier">
        <id property="id" column="id"/>
        <result property="supplierName" column="supplier_name"/>
        <result property="contactPerson" column="contact"/>
        <result property="phone" column="phone"/>
        <result property="address" column="address"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 新增 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into supplier
        (supplier_name, contact, phone, address)
        values
        (#{supplierName}, #{contactPerson}, #{phone}, #{address})
    </insert>

    <!-- 修改 -->
    <update id="updateById">
        update supplier
        set supplier_name=#{supplierName},
        contact=#{contactPerson},
        phone=#{phone},
        address=#{address},
        update_time=now()
        where id=#{id}
    </update>

    <!-- 删除 -->
    <delete id="deleteById">
        delete from supplier where id=#{id}
    </delete>

    <!-- 查询单个 -->
    <select id="getById" resultMap="supplierMap">
        select * from supplier where id=#{id}
    </select>

    <!-- 查询全部 -->
    <select id="list" resultMap="supplierMap">
        select * from supplier
    </select>

    <select id="searchByName" resultMap="supplierMap">
        select * from supplier
        where supplier_name like concat('%', #{keyword}, '%')
        limit 50
    </select>
</mapper>