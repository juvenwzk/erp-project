# 复制为 .env 后修改：copy .env.example .env

# 数据库（应用连接用 ERP_USER，不用 root）
MYSQL_USER=ERP_USER
MYSQL_PASSWORD=请设置强密码
MYSQL_ROOT_PASSWORD=请设置强密码
MYSQL_DATABASE=erp

DEEPSEEK_API_KEY=your-deepseek-api-key

# 阿里云 OSS（可选；Docker 未配置时将图片保存到容器 /app/uploads 并通过 /uploads/ 访问）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET=kangcode-erp
ALIYUN_OSS_REGION=cn-beijing
